Ottimizzazione della sintropia tramite gradient descent.

```python
import numpy as np
from typing import List
from core.nodes import Node
from core.coherence import CoherenceSystem

class SyntropyOptimizer:
    """Ottimizzatore della sintropia tramite gradient descent."""

    def __init__(self, nodes: List[Node], learning_rate: float = 0.01):
        self.nodes = nodes
        self.learning_rate = learning_rate
        self.coherence_system = CoherenceSystem(nodes)

    def compute_gradient(self) -> np.ndarray:
        """Calcola il gradiente della sintropia rispetto ai nodi."""
        gradient = np.zeros(len(self.nodes))
        for i, node in enumerate(self.nodes):
            # Approssimazione numerica del gradiente
            delta = 0.001
            node.update_coherence(delta)
            syntropy_plus = self.coherence_system.compute_syntropy()
            node.update_coherence(-2 * delta)  # Ripristina
            syntropy_minus = self.coherence_system.compute_syntropy()
            node.update_coherence(delta)  # Ripristina
            gradient[i] = (syntropy_plus - syntropy_minus) / (2 * delta)
        return gradient

    def optimize(self, iterations: int = 100) -> None:
        """Ottimizza la sintropia tramite gradient descent."""
        for _ in range(iterations):
            gradient = self.compute_gradient()
            for i, node in enumerate(self.nodes):
                node.update_coherence(self.learning_rate * gradient[i])
                node.update_vitality(self.learning_rate * gradient[i] * 0.5)  # Peso minore per vitalità
