## **2. Implementazione dei Moduli Core**
### **2.1 `core/nodes.py`**
Definizione della classe `Node` con proprietà e metodi per calcolare coerenza e vitalità.

```python
from dataclasses import dataclass
import numpy as np
from typing import Optional

@dataclass
class Node:
    """Nodo del sistema Nexus/Lex Amoris."""
    id: int
    initial_coherence: float  # [0, 1]
    initial_vitality: float   # [0, 1]
    ownership: bool           # True = privato, False = pubblico
    energy_consumption: float = 0.0  # kWh/h (pre-trasmutazione)
    energy_regeneration: float = 0.0 # kWh/h (post-trasmutazione)
    energy_biosys: float = 0.0       # kWh/h iniettati in sistemi biologici

    def update_coherence(self, delta: float) -> None:
        """Aggiorna la coerenza del nodo con un delta (es. +0.01 per interazioni positive)."""
        self.initial_coherence = np.clip(self.initial_coherence + delta, 0, 1)

    def update_vitality(self, delta: float) -> None:
        """Aggiorna la vitalità del nodo (es. +0.02 per buone pratiche ambientali)."""
        self.initial_vitality = np.clip(self.initial_vitality + delta, 0, 1)

    def get_state(self) -> dict:
        """Restituisce lo stato corrente del nodo."""
        return {
            "id": self.id,
            "coherence": self.initial_coherence,
            "vitality": self.initial_vitality,
            "ownership": self.ownership,
            "energy_consumption": self.energy_consumption,
            "energy_regeneration": self.energy_regeneration,
            "energy_biosys": self.energy_biosys,
        }
```

