### **2.2 `core/coherence.py`**
Calcolo della coerenza globale e sintropia.

```python
import numpy as np
from typing import List
from .nodes import Node

class CoherenceSystem:
    """Sistema per il calcolo della coerenza globale e sintropia."""

    def __init__(self, nodes: List[Node], alpha: float = 0.6, beta: float = 0.4):
        self.nodes = nodes
        self.alpha = alpha  # Peso coerenza
        self.beta = beta    # Peso vitalità
        self.global_coherence_threshold = 0.98

    def compute_global_coherence(self) -> float:
        """Calcola la coerenza globale come media dei nodi."""
        return np.mean([node.initial_coherence for node in self.nodes])

    def compute_syntropy(self) -> float:
        """Calcola la sintropia globale."""
        return sum(
            self.alpha * node.initial_coherence + self.beta * node.initial_vitality
            for node in self.nodes
        )

    def check_lex_amorris(self) -> bool:
        """Verifica se il sistema soddisfa Lex Amoris."""
        return self.compute_global_coherence() >= self.global_coherence_threshold

    def get_syntropy_components(self) -> dict:
        """Restituisce i componenti della sintropia."""
        return {
            "coherence_component": sum(node.initial_coherence for node in self.nodes),
            "vitality_component": sum(node.initial_vitality for node in self.nodes),
        }
