```python
from typing import List
from .nodes import Node

class EnergySystem:
    """Sistema per la gestione dell'energia (pre/post trasmutazione)."""

    def __init__(self, nodes: List[Node]):
        self.nodes = nodes

    def compute_consumed_energy(self, delta_time: float = 1.0) -> float:
        """Energia consumata (pre-trasmutazione)."""
        return sum(node.energy_consumption * delta_time for node in self.nodes)

    def compute_net_energy(self, delta_time: float = 1.0) -> float:
        """Energia netta rigenerativa (post-trasmutazione)."""
        return sum(
            (node.energy_regeneration - node.energy_biosys) * delta_time
            for node in self.nodes
        )

    def is_energy_positive(self) -> bool:
        """Verifica se il sistema ha energia positiva."""
        return self.compute_net_energy() >= 0

    def get_energy_balance(self) -> dict:
        """Restituisce il bilancio energetico."""
        return {
            "consumed": self.compute_consumed_energy(),
            "regenerated": sum(node.energy_regeneration for node in self.nodes),
            "biosys_injected": sum(node.energy_biosys for node in self.nodes),
            "net": self.compute_net_energy(),
        }
