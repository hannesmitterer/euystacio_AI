        self.nodes = nodes
        self.locked = False

    def attempt_rollback(self) -> bool:
        """Simula un tentativo di rollback (es. attacco informatico)."""
        if self.locked:
            return False  # Rollback bloccato
        return True  # Rollback consentito (sistema vulnerabile)

    def lock_system(self) -> None:
        """Blocca il sistema per prevenire rollback."""
        self.locked = True

    def unlock_system(self) -> None:
        """Sblocca il sistema (solo in emergenza)."""
        self.locked = False
