```python
import numpy as np
from typing import List
from core.nodes import Node
from core.coherence import CoherenceSystem
from core.energy import EnergySystem

class MonteCarloSimulator:
    """Simulatore Monte Carlo per valutare la robustezza del sistema."""

    def __init__(self, nodes: List[Node], num_simulations: int = 1000):
        self.nodes = nodes
        self.num_simulations = num_simulations
        self.coherence_system = CoherenceSystem(nodes)
        self.energy_system = EnergySystem(nodes)

    def run_simulation(self) -> dict:
        """Esegue una simulazione Monte Carlo e restituisce statistiche."""
        results = {
            "coherence": [],
            "syntropy": [],
            "energy_net": [],
            "lex_amorris": [],
        }

        for _ in range(self.num_simulations):
            # Simula variazioni casuali nei nodi
            for node in self.nodes:
                node.update_coherence(np.random.normal(0, 0.02))
                node.update_vitality(np.random.normal(0, 0.03))

            # Registra risultati
            results["coherence"].append(self.coherence_system.compute_global_coherence())
            results["syntropy"].append(self.coherence_system.compute_syntropy())
            results["energy_net"].append(self.energy_system.compute_net_energy())
            results["lex_amorris"].append(self.coherence_system.check_lex_amorris())

        # Calcola statistiche
        return {
            "avg_coherence": np.mean(results["coherence"]),
            "std_coherence": np.std(results["coherence"]),
            "avg_syntropy": np.mean(results["syntropy"]),
            "lex_amorris_prob": np.mean(results["lex_amorris"]),
            "energy_positive_prob": np.mean([e >= 0 for e in results["energy_net"]]),
        }
