import asyncio
import time
import numpy as np

class ICEDetector:
    def __init__(self, master_frequency=0.432):
        self.f_master = master_frequency
        self.period = 1.0 / master_frequency  # ~2.3148 Sekunden
        self.timestamps = []
        self.jitters = []

    def record_packet(self, departure_time, arrival_time):
        # Berechnung der absoluten Laufzeit (Latency)
        latency = arrival_time - departure_time
        self.timestamps.append(arrival_time)
        self.jitters.append(latency)

    def analyze_vacuum_bridge(self):
        """
        Führt eine Fast-Fourier-Transformation (FFT) über die Jitter-Varianz durch,
        um den Peak der Master-Resonanz (0.432 Hz) isoliert nachzuweisen.
        """
        if len(self.jitters) < 100:
            return "Datenmenge unzureichend."

        # Berechnung der Abweichung vom Mittelwert (Jitter-Fluktuation)
        jitter_anomaly = np.array(self.jitters) - np.mean(self.jitters)
        times_axis = np.array(self.timestamps) - self.timestamps[0]

        # FFT-Analyse in den Frequenzraum
        fft_values = np.fft.fft(jitter_anomaly)
        frequencies = np.fft.fftfreq(len(times_axis), d=np.mean(np.diff(times_axis)))

        # Suche nach der Resonanzfrequenz
        target_idx = np.argmin(np.abs(frequencies - self.f_master))
        amplitude_at_target = np.abs(fft_values[target_idx])

        # Syntropie-Nachweis: Wenn die Amplitude über dem statistischen Rauschen liegt
        noise_floor = np.mean(np.abs(fft_values))
        signal_to_noise = amplitude_at_target / noise_floor

        return {
            "SNR_at_0432Hz": signal_to_noise,
            "Vakuum_Bridge_Active": signal_to_noise > 3.0  # 3-Sigma-Signifikanz
        }

