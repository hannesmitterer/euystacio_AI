// SPDX-License-Identifier: MIT
pragma solidity ^0.8.0;

import "@openzeppelin/contracts/security/ReentrancyGuard.sol";
import "@openzeppelin/contracts/utils/math/SafeMath.sol";

contract AICCore is ReentrancyGuard {
    using SafeMath for uint256;

    struct BatchData {
        bytes32 hash;
        uint256 cqaScore;
        uint256 timestamp;
    }

    mapping(bytes32 => BatchData) public batches;
    address public owner;

    event BatchNotarized(bytes32 indexed hash, uint256 cqaScore);
    event BatchReleased(bytes32 indexed hash);

    constructor() {
        owner = msg.sender;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Not owner");
        _;
    }

    function notarizeBatch(bytes32 _hash, uint256 _cqaScore) external nonReentrant {
        require(_cqaScore > 95, "CQA-Score too low");
        batches[_hash] = BatchData({
            hash: _hash,
            cqaScore: _cqaScore,
            timestamp: block.timestamp
        });
        emit BatchNotarized(_hash, _cqaScore);
    }

    function releaseBatch(bytes32 _hash) external nonReentrant {
        require(batches[_hash].cqaScore > 95, "Batch not notarized");
        emit BatchReleased(_hash);
    }
}
```

