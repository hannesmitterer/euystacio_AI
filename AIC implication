**🔧 Beispiel-Code für PT100-Messung (ESP32-S3):**
```cpp
#include <Arduino.h>
#include <Adafruit_ADS1X15.h> // ADC-Wandler für PT100

Adafruit_ADS1115 ads; // 16-Bit ADC

float readPT100() {
  int16_t adcValue = ads.readADC_SingleEnded(0); // PT100 an Kanal 0
  float voltage = (adcValue * 4.096) / 32767.0; // ADS1115: 4,096V Referenz
  float resistance = (voltage * 10000.0) / (3.3 - voltage); // Spannungsteiler
  float temperature = (resistance - 100.0) / 0.385; // PT100: 0,385 Ω/°C
  return temperature;
}

void setup() {
  Serial.begin(115200);
  ads.begin();
}

void loop() {
  float temp = readPT100();
  Serial.print("Temperatur: ");
  Serial.print(temp);
  Serial.println(" °C");
  delay(1000);
}
```

