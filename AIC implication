import hashlib
import json
from datetime import datetime

def log_gmp_event(event_type, data, ipfs_client):
    # Erstelle Audit-Eintrag
    audit_entry = {
        "timestamp": datetime.utcnow().isoformat(),
        "event_type": event_type,
        "data": data,
        "hash": hashlib.sha3_512(json.dumps(data).encode()).hexdigest()
    }

    # Speichere in IPFS
    ipfs_hash = ipfs_client.add_json(audit_entry)
    print(f"GMP-Log gespeichert in IPFS: {ipfs_hash}")

    # Speichere Hash in Smart Contract
    aic_core.notarizeBatch(ipfs_hash, data["cqa_score"])

# Beispielaufruf
log_gmp_event(
    event_type="temperature_check",
    data={"temperature": 37.2, "unit": "°C", "cqa_score": 0.98},
    ipfs_client=ipfs_client
)
```

