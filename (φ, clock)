from dataclasses import dataclass
import numpy as np

@dataclass
class NodeEnergy:
    id: int
    old_consumption: float  # kWh/h (baseline legacy)
    new_regeneration: float # kWh/h (post-trasmutazione)
    biosys_injection: float # kWh/h iniettati in sistemi biologici

class EnergySystem:
    """Sistema per la gestione dell'energia (consumo, rigenerazione, bilancio)."""

    def __init__(self, nodes: list[NodeEnergy]):
        self.nodes = nodes

    def compute_consumed_energy(self, delta_time: float = 1.0) -> float:
        """Energia consumata (pre-trasmutazione)."""
        return sum(node.old_consumption * delta_time for node in self.nodes)

    def compute_net_energy(self, delta_time: float = 1.0) -> float:
        """Energia netta rigenerativa (post-trasmutazione)."""
        return sum(
            (node.new_regeneration - node.biosys_injection) * delta_time
            for node in self.nodes
        )

    def is_energy_positive(self) -> bool:
        """Verifica se il sistema ha energia positiva."""
        return self.compute_net_energy() >= 0

    def get_sroi(self, data_ethics: float = 100.0) -> float:
        """Calcola S-ROI (Social Return on Investment)."""
        parasite_compute = self.compute_consumed_energy() * 0.1  # Stima
        return (data_ethics - parasite_compute) / self.compute_net_energy()

# Esempio di utilizzo
nodes_energy = [
    NodeEnergy(id=1, old_consumption=1000, new_regeneration=600, biosys_injection=200),
    NodeEnergy(id=2, old_consumption=1500, new_regeneration=800, biosys_injection=300),
]
energy_system = EnergySystem(nodes_energy)
print(f"Energia netta: {energy_system.compute_net_energy():.2f} MW")
print(f"S-ROI: {energy_system.get_sroi():.2f} G-Unit/Watt")
print(f"Sistema a energia positiva: {energy_system.is_energy_positive()}")
