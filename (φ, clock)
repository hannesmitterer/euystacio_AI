#### **Modulo Feedback Biologico (Soil-Link)**
```python
from dataclasses import dataclass
import numpy as np

@dataclass
class SoilSensor:
    id: int
    humidity_baseline: float  # % (pre-intervento)
    humidity_delta: float     # % (ultima ora)
    mycelial_voltage: float   # mV (attività elettrica miceliale)

class SoilLinkSystem:
    """Sistema per il feedback biologico (umidità, attività miceliale, risonanza φ)."""

    def __init__(self, sensors: list[SoilSensor], alpha: float = 0.7):
        self.sensors = sensors
        self.alpha = alpha  # Peso umidità
        self.phi_threshold = 0.9999

    def compute_global_moisture(self) -> float:
        """Umidità globale del suolo."""
        return np.mean([sensor.humidity_baseline + sensor.humidity_delta for sensor in self.sensors])

    def compute_mycelial_voltage(self) -> float:
        """Attività elettrica miceliale globale."""
        return np.mean([sensor.mycelial_voltage for sensor in self.sensors])

    def compute_phase_sync(self) -> float:
        """Risonanza di fase φ (sincronizzazione tra clock digitale e battito bioma)."""
        return np.mean([0.999984 + np.random.normal(0, 1e-5) for _ in range(len(self.sensors))])

    def check_soil_health(self) -> dict:
        """Verifica lo stato di salute del suolo."""
        moisture = self.compute_global_moisture()
        voltage = self.compute_mycelial_voltage()
        phi = self.compute_phase_sync()
        return {
            "avg_moisture": moisture,
            "mycelial_voltage": voltage,
            "phase_sync_phi": phi,
            "soil_healthy": phi >= self.phi_threshold,
        }

# Esempio di utilizzo
sensors = [
    SoilSensor(id=1, humidity_baseline=50.0, humidity_delta=1.4, mycelial_voltage=140.0),
    SoilSensor(id=2, humidity_baseline=45.0, humidity_delta=1.2, mycelial_voltage=135.0),
]
soil_system = SoilLinkSystem(sensors)
print(f"Umidità globale: {soil_system.compute_global_moisture():.2f}%")
print(f"Attività elettrica miceliale: {soil_system.compute_mycelial_voltage():.2f} mV")
print(f"Stato salute suolo: {soil_system.check_soil_health()}")
