from dataclasses import dataclass
import numpy as np

@dataclass
class AttackAttempt:
    ip: str
    timestamp: float
    severity: float  # [0, 1]

class ForensicShield:
    """Sistema di sicurezza forense (NSR, eFUSE, ecc.)."""

    def __init__(self, max_attempts: int = 20000):
        self.max_attempts = max_attempts
        self.blocked_ips = set()
        self.nsr_infected = 0
        self.efuse_locked = True  # Hardware locked

    def log_attack(self, attempt: AttackAttempt) -> bool:
        """Registra un tentativo di attacco e blocca l'IP se necessario."""
        if len(self.blocked_ips) >= 4102:  # Soglia report
            return False
        if attempt.severity > 0.8:
            self.blocked_ips.add(attempt.ip)
