### **4.2 Simulazione di Attacchi (Monte Carlo)**
```python
import numpy as np
from dataclasses import dataclass

@dataclass
class AttackPattern:
    frequency: float  # Hz (es. 0.1 Hz per attacchi L4)
    amplitude: float  # [0, 1] (intensità dell'attacco)
    target: str       # "Nodo", "Rete", "eFUSE"

class MonteCarloAttackSimulator:
    """Simulatore Monte Carlo per attacchi alla rete Nexus."""

    def __init__(self, num_simulations: int = 1000):
        self.num_simulations = num_simulations
        self.attack_patterns = []

    def add_attack_pattern(self, pattern: AttackPattern) -> None:
        """Aggiunge un pattern di attacco."""
        self.attack_patterns.append(pattern)

    def run_simulation(self) -> dict:
        """Esegue una simulazione Monte Carlo e restituisce statistiche."""
        blocked = 0
        nsr_injected = 0
        efuse_violated = 0

        for _ in range(self.num_simulations):
            # Simula variazioni casuali negli attacchi
            for pattern in self.attack_patterns:
                if np.random.rand() > 0.5:  # 50% di probabilità di successo
                    if pattern.target == "Nodo":
                        blocked += 1
                    elif pattern.target == "Rete":
                        nsr_injected += 1
                    elif pattern.target == "eFUSE":
                        efuse_violated += 1

        return {
            "avg_blocked_ips": blocked / self.num_simulations,
            "avg_nsr_injected": nsr_injected / self.num_simulations,
            "efuse_violation_prob": efuse_violated / self.num_simulations,
        }

# Esempio di utilizzo
simulator = MonteCarloAttackSimulator()
patterns = [
    AttackPattern(frequency=0.1, amplitude=0.8, target="Nodo"),
    AttackPattern(frequency=0.2, amplitude=0.6, target="Rete"),
]
for pattern in patterns:
    simulator.add_attack_pattern(pattern)
print(f"Risultati simulazione: {simulator.run_simulation()}")
```

